yarn-error.log*

# Frontend ignores
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/*.log

# Backend ignores
backend/node_modules/
backend/venv/
backend/__pycache__/
backend/.env
backend/*.pyc
*.py[cod] # More comprehensive Python bytecode ignores

